# Raw register extracts are large and regenerated daily; the committed
# data/manifest.json records exactly which snapshot this repo was built from.
data/raw/*
!data/raw/.gitkeep

# Secrets — the real .env never leaves this machine (.env.example is committed)
.env

# Python
.venv/
__pycache__/
*.pyc

# The 300-charity preview sample stays local; the real dataset is committed
outputs/sample_tags_preview.csv

# Labelling working files (save journal + safety backup made by label_ui.py)
outputs/validation/*.journal.jsonl
outputs/validation/*.startup-backup.xlsx

# Local editor/tooling config (contains machine-specific paths)
.claude/

# Private planning notes
PLAN.md

# macOS
.DS_Store
